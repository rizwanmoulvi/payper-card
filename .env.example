# Set this in your KeeperHub workflow's `notify-agent` HTTP action body 
# (use ngrok to test locally)
AGENT_CALLBACK_URL="http://localhost:3000/agent-callback"

# Use the public x402.org testnet facilitator (No API key required!)
# Network: Base Sepolia (eip155:84532)
X402_FACILITATOR_URL="https://x402.org/facilitator"
USDC_SEP_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
X402_PAY_TO_ADDRESS="0x06A7E46392a6e505B032BAdCE7dc40C07d620caa"

# Hackathon specific variables
# KeeperHub uses secure generated Turnkey Enclave wallets, so you cannot directly "import" a private key.
# Instead, you'll copy your KeeperHub Turnkey address here, and run `node src/fund-keeperhub.js` 
# to sweep the USDC & ETH from the funded key below into your KeeperHub wallet before the demo.
KEEPERHUB_TURNKEY_ADDRESS="0x..."
FUNDED_WALLET_ADDRESS=""
FUNDED_WALLET_PRIVATE_KEY=""
